# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
env_isaacsim/

# Output artifacts
output/

# External/heavy directories
IsaacLab/
MotionComparator/
arm_coverage/
curobo/

# Locally-built ROS overlay (topic_based_ros2_control from source) — build artifact
ros2_overlay/

# Julia depot (GLNS.jl packages) — JULIA_DEPOT_PATH, populated by install_env.sh
.julia/

# Local tool state
.claude/
CLAUDE.md

# Isaac Sim auto-generated caches/artifacts
.thumbs/
Collected_*/

# Capture videos (large binary, do not version)
data/**/video*/

# reorient_mesh.py backups
*.obj.bak

# 외부 반입 자료(대용량 CAD/스크래치 텍스처 드롭)
ff/

# Blender 작업파일(메시 편집용 소스, 산출물인 source.usd만 버전관리)
*.blend
*.blend[0-9]*

# 실험 산출물(솔버 결과 JSON/H5, 플롯) — 버전관리 제외
runs/

# 로컬 테스트 — 버전관리 제외(로컬에는 유지)
tests/

# 로컬 문서 이력 — 현행 사용자 문서만 버전관리
/docs/logs/
/docs/archive/
