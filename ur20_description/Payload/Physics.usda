#usda 1.0
(
    customLayerData = {
        string creator = "URDF USD Converter v0.1.0"
    }
    defaultPrim = "ur"
    kilogramsPerUnit = 1
    metersPerUnit = 1
    upAxis = "Z"
)

def Xform "ur"
{
    def Scope "Physics"
    {
        def PhysicsFixedJoint "base_joint"
        {
            rel physics:body0 = </ur>
            rel physics:body1 = </ur/Geometry/world/base_link>
            point3f physics:localPos0 = (0, 0, 0)
            point3f physics:localPos1 = (0, 0, 0)
            quatf physics:localRot0 = (1, 0, 0, 0)
            quatf physics:localRot1 = (1, 0, 0, 0)
        }

        def PhysicsFixedJoint "tn__base_linkbase_link_inertia_kc0" (
            displayName = "base_link-base_link_inertia"
        )
        {
            rel physics:body0 = </ur>
            rel physics:body1 = </ur/Geometry/world/base_link/base_link_inertia>
            point3f physics:localPos0 = (0, 0, 0)
            point3f physics:localPos1 = (0, 0, 0)
            quatf physics:localRot0 = (6.123234e-17, 0, 0, 1)
            quatf physics:localRot1 = (1, 0, 0, 0)
        }

        def PhysicsRevoluteJoint "shoulder_pan_joint"
        {
            uniform token physics:axis = "Z"
            rel physics:body0 = </ur>
            rel physics:body1 = </ur/Geometry/world/base_link/base_link_inertia/shoulder_link>
            point3f physics:localPos0 = (0, 0, 0.2363)
            point3f physics:localPos1 = (0, 0, 0)
            quatf physics:localRot0 = (6.123234e-17, 0, 0, 1)
            quatf physics:localRot1 = (1, 0, 0, 0)
            float physics:lowerLimit = -360
            float physics:upperLimit = 360
            custom float urdf:dynamics:damping = 0
            custom float urdf:dynamics:friction = 0
            custom float urdf:limit:effort = 738
            custom float urdf:limit:velocity = 2.0943952
        }

        def PhysicsRevoluteJoint "shoulder_lift_joint"
        {
            uniform token physics:axis = "Z"
            rel physics:body0 = </ur>
            rel physics:body1 = </ur/Geometry/world/base_link/base_link_inertia/shoulder_link/upper_arm_link>
            point3f physics:localPos0 = (0, 0, 0.2363)
