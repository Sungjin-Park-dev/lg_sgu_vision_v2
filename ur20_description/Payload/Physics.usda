                                        float3 physics:diagonalInertia = (0.0041839294, 0.0058571305, 0.00586894)
                                        float physics:mass = 3.126
                                        quatf physics:principalAxes = (0.70286906, -0.111626655, 0.6509824, -0.26407674)

                                        over "wrist2_1" (
                                            prepend apiSchemas = ["PhysicsCollisionAPI", "NewtonCollisionAPI", "PhysicsMeshCollisionAPI", "NewtonMeshCollisionAPI"]
                                        )
