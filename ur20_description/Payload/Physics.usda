                                }

                                over "wrist_1_link" (
                                    prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI"]
                                )
                                {
                                    point3f physics:centerOfMass = (0, -0.0393, -0.0026)
                                    float3 physics:diagonalInertia = (0.0039298222, 0.00545771, 0.005552468)
                                    float physics:mass = 3.054
                                    quatf physics:principalAxes = (0.52442473, 0.47981063, 0.38836336, 0.58645916)

                                    over "wrist1_1" (
                                        prepend apiSchemas = ["PhysicsCollisionAPI", "NewtonCollisionAPI", "PhysicsMeshCollisionAPI", "NewtonMeshCollisionAPI"]
                                    )
                                    {
                                        uniform token physics:approximation = "convexHull"
                                    }

                                    over "wrist_2_link" (
                                        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI"]
                                    )
