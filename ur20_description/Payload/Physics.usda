            rel physics:body1 = </ur/Geometry/world/base_link/base_link_inertia/shoulder_link/upper_arm_link/forearm_link/wrist_1_link/wrist_2_link/wrist_3_link/ft_frame>
            point3f physics:localPos0 = (1.5907, 0.3553, 0.076999985)
