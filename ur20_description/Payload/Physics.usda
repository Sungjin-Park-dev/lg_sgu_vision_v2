        {
            rel physics:body0 = </ur>
            rel physics:body1 = </ur/Geometry/world/base_link/base_link_inertia/shoulder_link/upper_arm_link/forearm_link/wrist_1_link/wrist_2_link/wrist_3_link/flange/tool0/camera_frame_1/camera_frame_2/camera_link/camera_optical_frame>
            point3f physics:localPos0 = (1.5907797, 0.5893, 0.07699998)
            point3f physics:localPos1 = (0, 0, 0)
            quatf physics:localRot0 = (-3.8285688e-16, 1.10300233e-16, 0.70710677, 0.70710677)
            quatf physics:localRot1 = (1, 0, 0, 0)
        }
    }

    over "Geometry"
    {
        over "world"
        {
            over "base_link" (
                prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsArticulationRootAPI", "NewtonArticulationRootAPI"]
            )
            {
                over "base_link_inertia" (
                    prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI"]
                )
                {
                    point3f physics:centerOfMass = (0, 0, 0)
                    float3 physics:diagonalInertia = (0.006106331, 0.006106331, 0.01125)
                    float physics:mass = 4
                    quatf physics:principalAxes = (1, 0, 0, 0)

                    over "base_1" (
                        prepend apiSchemas = ["PhysicsCollisionAPI", "NewtonCollisionAPI", "PhysicsMeshCollisionAPI", "NewtonMeshCollisionAPI"]
                    )
                    {
                        uniform token physics:approximation = "convexHull"
                    }

                    over "shoulder_link" (
                        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI"]
                    )
                    {
                        point3f physics:centerOfMass = (0, -0.0062, -0.061)
                        float3 physics:diagonalInertia = (0.072047174, 0.08837347, 0.08873936)
                        float physics:mass = 16.343
                        quatf physics:principalAxes = (-0.707691, -0.018194258, 0.34470356, 0.61645913)

                        over "shoulder_1" (
                            prepend apiSchemas = ["PhysicsCollisionAPI", "NewtonCollisionAPI", "PhysicsMeshCollisionAPI", "NewtonMeshCollisionAPI"]
                        )
                        {
                            uniform token physics:approximation = "convexHull"
                        }

                        over "upper_arm_link" (
                            prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI"]
                        )
                        {
                            point3f physics:centerOfMass = (-0.3394, 0, 0.2098)
                            float3 physics:diagonalInertia = (0.14610614, 4.6353936, 4.6659)
                            float physics:mass = 29.632
                            quatf physics:principalAxes = (-0.70665663, 0.70753324, -0.004078837, 0.004054083)

                            over "upperarm_1" (
                                prepend apiSchemas = ["PhysicsCollisionAPI", "NewtonCollisionAPI", "PhysicsMeshCollisionAPI", "NewtonMeshCollisionAPI"]
                            )
                            {
                                uniform token physics:approximation = "convexHull"
                            }

                            over "forearm_link" (
                                prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI"]
                            )
                            {
