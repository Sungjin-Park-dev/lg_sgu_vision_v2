                                            )
                                            {
                                            }

                                            over "flange" (
                                                prepend apiSchemas = ["PhysicsRigidBodyAPI"]
                                            )
                                            {
                                                over "tool0" (
                                                    prepend apiSchemas = ["PhysicsRigidBodyAPI"]
                                                )
                                                {
                                                    over "camera_cable_frame" (
                                                        prepend apiSchemas = ["PhysicsRigidBodyAPI"]
                                                    )
                                                    {
