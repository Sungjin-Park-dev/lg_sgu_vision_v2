            rel physics:body0 = </ur>
            rel physics:body1 = </ur/Geometry/world/base_link/base_link_inertia/shoulder_link/upper_arm_link/forearm_link/wrist_1_link/wrist_2_link/wrist_3_link/flange/tool0/camera_cable_frame>
            point3f physics:localPos0 = (1.5907, 0.32529998, -0.023000017)
